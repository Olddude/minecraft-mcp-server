{
  "name": "@olddude/minecraft-mcp-server",
  "version": "0.1.0",
  "main": "dist/bot.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "minecraft-mcp-server": "dist/bot.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "lint": "eslint . -c eslint.config.mjs --ignore-pattern dist",
    "lint:fix": "npm run lint -- --fix",
    "test:ci": "jest --coverage",
    "test": "npm run test:ci -- --watch",
    "build": "node -r dotenv/config esbuild.config.mjs",
    "start:debug": "node -r dotenv/config -r ts-node/register index.ts",
    "start:release": "node -r dotenv/config dist/index.js",
    "start": "nodemon"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.4",
    "minecraft-data": "^3.89.0",
    "mineflayer": "^4.0.0",
    "mineflayer-pathfinder": "^2.4.2",
    "vec3": "^0.1.8",
    "yargs": "^17.7.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.19",
    "@types/vec3": "^0.1.4",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "dotenv": "^16.5.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "husky": "^9.1.4",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0"
  }
}